<Window x:Class="FileTransformer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FileTransformer.App.ViewModels"
        xmlns:views="clr-namespace:FileTransformer.App.Views"
        mc:Ignorable="d"
        Title="FileKitsune"
        Icon="/Assets/filekitsune.png"
        Width="1360"
        Height="860"
        MinWidth="980"
        MinHeight="720">
    <Window.Resources>
        <Style x:Key="WizardStepTitleStyle"
                TargetType="TextBlock">
            <Setter Property="Text"
                    Value="{DynamicResource WizardStepFolderTitle}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.ModeSelector}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepModeSelectorTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Strategy}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepStrategyTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Rules}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepRulesTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Preview}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepPreviewTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepExecuteTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.DedupScan}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepDedupScanTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.DedupReview}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepDedupReviewTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.DedupExecute}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepDedupExecuteTitle}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Legal}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepLegalTitle}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizardStepBodyStyle"
                TargetType="TextBlock">
            <Setter Property="Text"
                    Value="{DynamicResource WizardStepFolderBody}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.ModeSelector}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepModeSelectorBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Strategy}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepStrategyBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Rules}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepRulesBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Preview}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepPreviewBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepExecuteBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.DedupScan}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepDedupScanBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.DedupReview}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepDedupReviewBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.DedupExecute}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepDedupExecuteBody}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}"
                        Value="{x:Static viewModels:WizardStep.Legal}">
                    <Setter Property="Text"
                            Value="{DynamicResource WizardStepLegalBody}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepBadgeBorderStyle"
                TargetType="Border">
            <Setter Property="Padding"
                    Value="10,8"/>
            <Setter Property="Margin"
                    Value="0,0,0,10"/>
            <Setter Property="CornerRadius"
                    Value="14"/>
            <Setter Property="Background"
                    Value="#14FFFFFF"/>
            <Setter Property="BorderBrush"
                    Value="#26FFFFFF"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
        </Style>

        <DataTemplate x:Key="FolderStepTemplate">
            <views:WizardFolderStepView/>
        </DataTemplate>

        <DataTemplate x:Key="ModeSelectorStepTemplate">
            <views:WizardModeSelectorView/>
        </DataTemplate>

        <DataTemplate x:Key="StrategyStepTemplate">
            <views:WizardStrategyStepView/>
        </DataTemplate>

        <DataTemplate x:Key="RulesStepTemplate">
            <views:WizardRulesStepView/>
        </DataTemplate>

        <DataTemplate x:Key="PreviewStepTemplate">
            <views:WizardPreviewStepView/>
        </DataTemplate>

        <DataTemplate x:Key="ExecuteStepTemplate">
            <views:WizardExecuteStepView/>
        </DataTemplate>

        <DataTemplate x:Key="DedupScanStepTemplate">
            <views:WizardDedupScanView/>
        </DataTemplate>

        <DataTemplate x:Key="DedupReviewStepTemplate">
            <views:WizardDedupReviewView/>
        </DataTemplate>

        <DataTemplate x:Key="DedupExecuteStepTemplate">
            <views:WizardDedupExecuteView/>
        </DataTemplate>

        <DataTemplate x:Key="LegalStepTemplate">
            <views:WizardLegalView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Ellipse Width="520"
                 Height="520"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-180,-120,0"
                 Fill="#26FFFFFF"
                 IsHitTestVisible="False"/>
        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-140,0,0,-120"
                 Fill="#1FFFFFFF"
                 IsHitTestVisible="False"/>

        <Border Style="{StaticResource CompactCardBorderStyle}"
                Padding="14"
                Background="{StaticResource HeroPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="1.75*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Width="128"
                            Height="128"
                            Padding="8"
                            HorizontalAlignment="Left"
                            Background="#18FFFFFF"
                            BorderBrush="#24FFFFFF"
                            BorderThickness="1"
                            CornerRadius="24">
                        <Image Source="/Assets/filekitsune.png"
                               Stretch="Uniform"/>
                    </Border>
                    <Border Style="{StaticResource PillBorderStyle}"
                            HorizontalAlignment="Left">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Text="{DynamicResource WizardLabel}"/>
                    </Border>
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource HeroTitleTextStyle}"
                               Text="{DynamicResource AppTitle}"/>
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource HintTextStyle}"
                               Text="{DynamicResource AppSubtitle}"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Style="{StaticResource SoftPanelBorderStyle}"
                        Padding="12"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{DynamicResource WizardLabel}"/>
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource WizardStepTitleStyle}"/>
                            <ProgressBar Margin="0,8,0,0"
                                         Minimum="1"
                                         Maximum="{Binding TotalWizardSteps, Mode=OneWay}"
                                         Value="{Binding CurrentStepNumber, Mode=OneWay}"
                                         Height="6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{DynamicResource SafetyGuardrailsTitle}"/>
                            <TextBlock Margin="0,2,0,0"
                                       Style="{StaticResource HintTextStyle}"
                                       Text="{Binding StatusMessage}"/>
                            <ProgressBar Margin="0,8,0,0"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="{Binding ProgressMaximum}"
                                         Value="{Binding ProgressValue}"
                                         IsIndeterminate="{Binding IsProgressIndeterminate}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="0,12,0,12"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate"
                                Value="{StaticResource ModeSelectorStepTemplate}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.Folder}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource FolderStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.Strategy}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource StrategyStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.Rules}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource RulesStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.Preview}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource PreviewStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource ExecuteStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.DedupScan}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource DedupScanStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.DedupReview}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource DedupReviewStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.DedupExecute}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource DedupExecuteStepTemplate}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}"
                                    Value="{x:Static viewModels:WizardStep.Legal}">
                                <Setter Property="ContentTemplate"
                                        Value="{StaticResource LegalStepTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Style="{StaticResource CompactCardBorderStyle}"
                Background="{StaticResource HeroPanelBrush}"
                Padding="12,10">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NextCommand}"
                        Content="{DynamicResource WizardNextButton}"
                        Visibility="{Binding IsWizardShellNavigationVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BackCommand}"
                        Content="{DynamicResource WizardBackButton}"
                        Visibility="{Binding IsWizardShellNavigationVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding OpenLegalCommand}"
                        Content="{DynamicResource LegalFooterButton}"/>
                <StackPanel>
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{DynamicResource WizardLabel}"/>
                    <TextBlock Margin="0,4,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Style="{StaticResource WizardStepTitleStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
