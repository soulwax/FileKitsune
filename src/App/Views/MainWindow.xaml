<Window x:Class="FileTransformer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FileTransformer.App.ViewModels"
        xmlns:views="clr-namespace:FileTransformer.App.Views"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Width="1480"
        Height="900"
        MinWidth="1200"
        MinHeight="780">
    <Window.Resources>
        <Style x:Key="WizardStepTitleStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="{DynamicResource WizardStepFolderTitle}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Strategy}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepStrategyTitle}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Rules}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepRulesTitle}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Preview}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepPreviewTitle}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepExecuteTitle}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizardStepBodyStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="{DynamicResource WizardStepFolderBody}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Strategy}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepStrategyBody}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Rules}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepRulesBody}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Preview}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepPreviewBody}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepExecuteBody}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="{DynamicResource AppTitle}" />
                    <TextBlock Margin="0,6,0,12"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{DynamicResource AppSubtitle}" />
                    <ProgressBar Height="10"
                                 Minimum="0"
                                 Maximum="{Binding ProgressMaximum}"
                                 Value="{Binding ProgressValue}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{Binding StatusMessage}" />

                    <Border Margin="0,18,0,0"
                            Padding="16"
                            Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="{DynamicResource WizardLabel}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource WizardStepTitleStyle}" />
                            <TextBlock Margin="0,6,0,10"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource WizardStepBodyStyle}" />
                            <ProgressBar Minimum="1"
                                         Maximum="{Binding TotalWizardSteps}"
                                         Value="{Binding CurrentStepNumber}"
                                         Height="8" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="20,0,0,0"
                        Padding="16,10"
                        Background="{StaticResource AccentSoftBrush}"
                        CornerRadius="14">
                    <StackPanel>
                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="{DynamicResource SafetyGuardrailsTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Width="250"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource SafetyGuardrailsBody}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,18,0,18" Style="{StaticResource CardBorderStyle}">
            <TabControl SelectedIndex="{Binding CurrentStepIndex, Mode=TwoWay}"
                        TabStripPlacement="None"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem>
                    <views:WizardFolderStepView />
                </TabItem>
                <TabItem>
                    <views:WizardStrategyStepView />
                </TabItem>
                <TabItem>
                    <views:WizardRulesStepView />
                </TabItem>
                <TabItem>
                    <views:WizardPreviewStepView />
                </TabItem>
                <TabItem>
                    <views:WizardExecuteStepView />
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NextCommand}"
                        Content="{DynamicResource WizardNextButton}" />
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BackCommand}"
                        Content="{DynamicResource WizardBackButton}" />
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{DynamicResource WizardLabel}" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource WizardStepTitleStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
