<Window x:Class="FileTransformer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FileTransformer.App.ViewModels"
        xmlns:views="clr-namespace:FileTransformer.App.Views"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Width="1360"
        Height="860"
        MinWidth="980"
        MinHeight="720">
    <Window.Resources>
        <Style x:Key="WizardStepTitleStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="{DynamicResource WizardStepFolderTitle}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Strategy}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepStrategyTitle}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Rules}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepRulesTitle}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Preview}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepPreviewTitle}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepExecuteTitle}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizardStepBodyStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="{DynamicResource WizardStepFolderBody}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Strategy}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepStrategyBody}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Rules}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepRulesBody}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Preview}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepPreviewBody}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                    <Setter Property="Text" Value="{DynamicResource WizardStepExecuteBody}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepBadgeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#26FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <DataTemplate x:Key="FolderStepTemplate">
            <views:WizardFolderStepView />
        </DataTemplate>

        <DataTemplate x:Key="StrategyStepTemplate">
            <views:WizardStrategyStepView />
        </DataTemplate>

        <DataTemplate x:Key="RulesStepTemplate">
            <views:WizardRulesStepView />
        </DataTemplate>

        <DataTemplate x:Key="PreviewStepTemplate">
            <views:WizardPreviewStepView />
        </DataTemplate>

        <DataTemplate x:Key="ExecuteStepTemplate">
            <views:WizardExecuteStepView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.Resources>
            <Style x:Key="InactiveStepNumberStyle" TargetType="Border" BasedOn="{StaticResource StepBadgeBorderStyle}">
                <Setter Property="Width" Value="34" />
                <Setter Property="Height" Value="34" />
                <Setter Property="CornerRadius" Value="17" />
                <Setter Property="Background" Value="#18FFFFFF" />
                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,12,0" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Ellipse Width="520"
                 Height="520"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-180,-120,0"
                 Fill="#26FFFFFF"
                 IsHitTestVisible="False" />
        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-140,0,0,-120"
                 Fill="#1FFFFFFF"
                 IsHitTestVisible="False" />

        <Border Style="{StaticResource CardBorderStyle}"
                Padding="24"
                Background="{StaticResource HeroPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="#30FFFFFF"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6"
                            HorizontalAlignment="Left">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Text="{DynamicResource WizardLabel}" />
                    </Border>
                    <TextBlock Margin="0,14,0,0"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Text="{DynamicResource AppTitle}" />
                    <TextBlock Margin="0,8,0,16"
                               FontSize="16"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{DynamicResource AppSubtitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{DynamicResource WizardLabel}" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Style="{StaticResource WizardStepTitleStyle}" />
                                <TextBlock Margin="0,6,0,14"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource WizardStepBodyStyle}" />
                                <ProgressBar Minimum="1"
                                             Maximum="{Binding TotalWizardSteps, Mode=OneWay}"
                                             Value="{Binding CurrentStepNumber, Mode=OneWay}"
                                             Height="10" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="{Binding StatusMessage}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource SafetyGuardrailsTitle}" />
                                <TextBlock Margin="0,8,0,14"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{DynamicResource SafetyGuardrailsBody}" />
                                <ProgressBar Height="8"
                                             Minimum="0"
                                             Maximum="{Binding ProgressMaximum}"
                                             Value="{Binding ProgressValue}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="24,0,0,0"
                        Padding="18"
                        Background="{StaticResource AccentPanelBrush}"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        CornerRadius="22">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentStrongBrush}"
                                   Text="{DynamicResource WizardLabel}" />

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Folder}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <Border Style="{StaticResource InactiveStepNumberStyle}">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="1" />
                                </Border>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{DynamicResource WizardStepFolderTitle}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                               Text="{DynamicResource WizardStepFolderBody}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Strategy}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <Border Style="{StaticResource InactiveStepNumberStyle}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="2" />
                                </Border>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{DynamicResource WizardStepStrategyTitle}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource WizardStepStrategyBody}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Rules}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <Border Style="{StaticResource InactiveStepNumberStyle}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="3" />
                                </Border>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{DynamicResource WizardStepRulesTitle}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource WizardStepRulesBody}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Preview}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <Border Style="{StaticResource InactiveStepNumberStyle}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="4" />
                                </Border>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{DynamicResource WizardStepPreviewTitle}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource WizardStepPreviewBody}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Margin="0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepBadgeBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HighlightBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <Border Style="{StaticResource InactiveStepNumberStyle}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="5" />
                                </Border>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{DynamicResource WizardStepExecuteTitle}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource WizardStepExecuteBody}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,20,0,20" Style="{StaticResource CardBorderStyle}" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate" Value="{StaticResource FolderStepTemplate}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Strategy}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource StrategyStepTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Rules}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource RulesStepTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.Preview}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource PreviewStepTemplate}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static viewModels:WizardStep.ExecuteRollback}">
                                    <Setter Property="ContentTemplate" Value="{StaticResource ExecuteStepTemplate}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Background="{StaticResource HeroPanelBrush}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NextCommand}"
                        Content="{DynamicResource WizardNextButton}" />
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding BackCommand}"
                        Content="{DynamicResource WizardBackButton}" />
                <StackPanel>
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{DynamicResource WizardLabel}" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Style="{StaticResource WizardStepTitleStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
