<UserControl x:Class="FileTransformer.App.Views.WizardExecuteStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource ExecuteActionTitle}" />
                        <TextBlock Margin="0,8,0,12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource ExecuteActionHint}" />
                        <Border Margin="0,0,0,12"
                                Style="{StaticResource SoftPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource ExecutionReviewTitle}" />
                                <TextBlock Margin="0,6,0,10"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ExecutionReviewSummaryText}" />
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{DynamicResource ExecutionReviewMoveLabel}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ExecutionReviewMoveCount}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{DynamicResource ExecutionReviewRenameLabel}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ExecutionReviewRenameCount}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{DynamicResource ExecutionReviewMoveRenameLabel}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ExecutionReviewMoveAndRenameCount}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{DynamicResource ExecutionReviewDuplicateLabel}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ExecutionReviewDuplicateCount}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{DynamicResource ExecutionReviewNeedsReviewLabel}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ExecutionReviewNeedsReviewCount}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{DynamicResource ExecutionReviewBlockedLabel}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ExecutionReviewBlockedCount}" />
                                    </StackPanel>
                                </UniformGrid>
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding ExecutionReviewSamples}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding}"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           Text="{Binding ExecutionReviewRemainingText}"
                                           Visibility="{Binding HasExecutionReviewRemainingText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,12"
                                Style="{StaticResource SoftPanelBorderStyle}"
                                Visibility="{Binding HasStalePreviewIssues, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource StalePreviewTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{DynamicResource StalePreviewBody}" />
                                <TextBlock Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Text="{Binding StalePreviewSummaryText}" />
                                <ItemsControl Margin="0,8,0,0"
                                              ItemsSource="{Binding StalePreviewIssues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding}"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Margin="0,8,0,0"
                                        Style="{StaticResource ProminentSecondaryButtonStyle}"
                                        Command="{Binding ScanCommand}"
                                        Content="{DynamicResource StalePreviewRebuildButton}" />
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource HeroActionButtonStyle}"
                                Command="{Binding ExecuteSelectedCommand}"
                                Content="{DynamicResource ExecuteButton}"
                                IsEnabled="{Binding CanExecuteSelectedOperations}" />
                        <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                                Command="{Binding CancelCurrentWorkCommand}"
                                Content="{DynamicResource CancelButton}"
                                IsEnabled="{Binding IsBusy}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PersistenceTitle}" />
                        <TextBlock Margin="0,8,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding PersistenceModeLabel}" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding PersistenceDetail}" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding PersistencePrimaryStore}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding PersistenceSecondaryStore}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource RollbackActionTitle}" />
                        <TextBlock Margin="0,8,0,12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource RollbackActionHint}" />
                        <Border Margin="0,0,0,12"
                                Style="{StaticResource SoftPanelBorderStyle}"
                                Visibility="{Binding HasIncompleteExecutionJournals, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource IncompleteExecutionJournalTitle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding IncompleteExecutionJournalSummary}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{DynamicResource IncompleteExecutionJournalBody}" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding PreviewSelectedRollbackRunCommand}"
                                            Content="{DynamicResource RecoveryPreviewButton}"
                                            IsEnabled="{Binding SelectedRollbackJournalNeedsRecovery}" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding RollbackSelectedCommand}"
                                            Content="{DynamicResource RecoveryRollbackButton}"
                                            IsEnabled="{Binding SelectedRollbackJournalNeedsRecovery}" />
                                    <Button Margin="8,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding MarkSelectedRollbackJournalAbandonedCommand}"
                                            Content="{DynamicResource RecoveryMarkAbandonedButton}"
                                            IsEnabled="{Binding SelectedRollbackJournalNeedsRecovery}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <StackPanel Margin="0,0,0,8"
                                    Visibility="{Binding HasRollbackHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Text="{DynamicResource RollbackHistoryLabel}" />
                            <TextBlock Margin="0,4,0,8"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{DynamicResource RollbackHistoryHint}" />
                            <ComboBox ItemsSource="{Binding RollbackHistory}"
                                      DisplayMemberPath="Label"
                                      SelectedItem="{Binding SelectedRollbackJournal}" />
                            <TextBlock Margin="0,8,0,8"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedRollbackJournalSummary}" />
                            <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                                    Command="{Binding PreviewSelectedRollbackRunCommand}"
                                    Content="{DynamicResource RollbackPreviewSelectedRunButton}"
                                    IsEnabled="{Binding HasSelectedRollbackJournal}" />
                        </StackPanel>
                        <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                                Command="{Binding RollbackLatestCommand}"
                                Content="{DynamicResource RollbackButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <Button Margin="0,8,0,0"
                                Style="{StaticResource ProminentSecondaryButtonStyle}"
                                Command="{Binding RollbackSelectedCommand}"
                                Content="{DynamicResource RollbackSelectedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding HasRollbackFolderGroups, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Text="{DynamicResource UndoByFolderLabel}" />
                            <ItemsControl ItemsSource="{Binding RollbackFolderGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,8,0,0"
                                                Style="{StaticResource SoftPanelBorderStyle}">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Label}" />
                                                <StackPanel Margin="0,10,0,0"
                                                            Orientation="Horizontal">
                                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.PreviewRollbackFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding FolderName}"
                                                            Content="{DynamicResource RollbackPreviewFolderButton}"
                                                            IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource InverseBooleanConverter}}" />
                                                    <Button Margin="8,0,0,0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.RollbackFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding FolderName}"
                                                            Content="{DynamicResource RollbackFolderUndoButton}"
                                                            IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource InverseBooleanConverter}}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PlanSummary}" />
                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryAnalyzedItemsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding TotalItems}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryMoveOperationsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding MoveCount}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryRenameOperationsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding RenameCount}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryItemsNeedingReviewLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding NeedsReviewCount}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryGeminiItemsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding GeminiAssistedCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <TabControl Grid.Column="2" Background="Transparent" BorderThickness="0">
            <TabItem Header="{DynamicResource ActivityTitle}">
                <Border Margin="8" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource SelectedOperationTitle}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource CurrentPathLabel}" />
                        <TextBlock Text="{Binding SelectedOperation.CurrentRelativePath}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ProposedPathLabel}" />
                        <TextBlock Text="{Binding SelectedOperation.ProposedRelativePath}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ReasonLabel}" />
                        <TextBlock Text="{Binding SelectedOperation.Reason}" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,10,0,0">
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ContentExtractionSourceLabel}" />
                            <TextBlock Margin="4,0,14,0" Text="{Binding SelectedOperation.ContentExtractionSource}" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       Text="{DynamicResource ContentExtractionConfidenceLabel}"
                                       Visibility="{Binding SelectedOperation.HasContentExtractionConfidence, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Margin="4,0,0,0"
                                       Text="{Binding SelectedOperation.ContentExtractionConfidence}"
                                       Visibility="{Binding SelectedOperation.HasContentExtractionConfidence, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="{DynamicResource RollbackPreviewTitle}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{DynamicResource RollbackPreviewHint}" />

                    <StackPanel Grid.Row="1"
                                Margin="0,12,0,0"
                                Visibility="{Binding HasRollbackPreviewEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource RollbackPreviewScopeTitle}" />
                                <TextBlock Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Text="{Binding RollbackPreviewScopeLabel}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding RollbackPreviewScopeBody}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource RollbackPreviewSummaryTitle}" />
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryReadyLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewReadyCount}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryMissingLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewMissingDestinationCount}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryBlockedLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewOriginalPathOccupiedCount}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryPendingLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewPendingNoMutationCount}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource RollbackPreviewDiffTitle}" />
                        <ItemsControl Margin="0,12,0,12"
                                      ItemsSource="{Binding RollbackPreviewSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Style="{StaticResource SoftPanelBorderStyle}">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Title}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Text="{Binding CountLabel}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,6,0,12"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Description}" />
                                            <ItemsControl ItemsSource="{Binding Entries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8"
                                                                Padding="12"
                                                                Background="{StaticResource SurfaceBrush}"
                                                                BorderBrush="{StaticResource LineBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding PreviewStatus}" />
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               Text="{Binding ExecutedAtLocal, StringFormat={}{0:g}}" />
                                                                </DockPanel>
                                                                <Grid Margin="0,10,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="32" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <iconPacks:PackIconFileIcons Width="24"
                                                                                                 Height="24"
                                                                                                 Margin="0,3,8,0"
                                                                                                 Foreground="{Binding FileTypeIconBrush}"
                                                                                                 Kind="{Binding FileTypeIconKind}" />
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                                                   Text="{DynamicResource RollbackPreviewCurrentColumn}" />
                                                                        <TextBlock Text="{Binding DestinationRelativePath}"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Grid>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           Text="{DynamicResource RollbackPreviewRestoreToColumn}" />
                                                                <TextBlock Text="{Binding SourceRelativePath}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           Text="{DynamicResource RollbackPreviewExpectedColumn}" />
                                                                <TextBlock Text="{Binding PreviewMessage}"
                                                                           TextWrapping="Wrap"
                                                                           Visibility="{Binding HasPreviewMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           Text="{DynamicResource RollbackPreviewReasonColumn}"
                                                                           Visibility="{Binding HasNotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <TextBlock Text="{Binding Notes}"
                                                                           TextWrapping="Wrap"
                                                                           Visibility="{Binding HasNotes, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding RemainingLabel}"
                                                       Visibility="{Binding HasRemainingLabel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource RollbackPreviewAuditTitle}" />
                        <DataGrid AutoGenerateColumns="False"
                                  Margin="0,12,0,0"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RollbackPreviewEntries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding ExecutedAtLocal, StringFormat={}{0:g}}"
                                                    Header="{DynamicResource RollbackPreviewWhenColumn}" />
                                <DataGridTemplateColumn Header="{DynamicResource RollbackPreviewFileColumn}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <iconPacks:PackIconFileIcons Width="20"
                                                                         Height="20"
                                                                         HorizontalAlignment="Center"
                                                                         Foreground="{Binding FileTypeIconBrush}"
                                                                         Kind="{Binding FileTypeIconKind}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding DestinationRelativePath}"
                                                    Header="{DynamicResource RollbackPreviewCurrentColumn}"
                                                    Width="2*" />
                                <DataGridTextColumn Binding="{Binding SourceRelativePath}"
                                                    Header="{DynamicResource RollbackPreviewRestoreToColumn}"
                                                    Width="2*" />
                                <DataGridTextColumn Binding="{Binding PreviewStatus}"
                                                    Header="{DynamicResource RollbackPreviewStatusColumn}" />
                                <DataGridTextColumn Binding="{Binding Outcome}"
                                                    Header="{DynamicResource RollbackPreviewOutcomeColumn}" />
                                <DataGridTextColumn Binding="{Binding PreviewMessage}"
                                                    Header="{DynamicResource RollbackPreviewExpectedColumn}"
                                                    Width="2*" />
                                <DataGridTextColumn Binding="{Binding Notes}"
                                                    Header="{DynamicResource RollbackPreviewReasonColumn}"
                                                    Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding HasRollbackPreviewEntries, Converter={StaticResource InverseBooleanConverter}}">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource RollbackPreviewEmpty}" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource LogsTitle}">
                <ListBox Margin="8"
                         BorderThickness="0"
                         ItemsSource="{Binding LogEntries}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Level}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding Category}" />
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding Message}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
