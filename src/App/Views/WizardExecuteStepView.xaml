<UserControl x:Class="FileTransformer.App.Views.WizardExecuteStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PreviewActions}" />
                        <TextBlock Margin="0,8,0,12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource ExecuteIntroText}" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ExecuteSelectedCommand}"
                                Content="{DynamicResource ExecuteButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelCurrentWorkCommand}"
                                Content="{DynamicResource CancelButton}"
                                IsEnabled="{Binding IsBusy}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PersistenceTitle}" />
                        <TextBlock Margin="0,8,0,8"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding PersistenceModeLabel}" />
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding PersistenceDetail}" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding PersistencePrimaryStore}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{Binding PersistenceSecondaryStore}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource RollbackTitle}" />
                        <TextBlock Margin="0,8,0,12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource RollbackBody}" />
                        <StackPanel Margin="0,0,0,8"
                                    Visibility="{Binding HasRollbackHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Text="{DynamicResource RollbackHistoryLabel}" />
                            <TextBlock Margin="0,4,0,8"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{DynamicResource RollbackHistoryHint}" />
                            <ComboBox ItemsSource="{Binding RollbackHistory}"
                                      DisplayMemberPath="Label"
                                      SelectedItem="{Binding SelectedRollbackJournal}" />
                            <TextBlock Margin="0,8,0,8"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedRollbackJournalSummary}" />
                        </StackPanel>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RollbackLatestCommand}"
                                Content="{DynamicResource RollbackButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <Button Margin="0,8,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RollbackSelectedCommand}"
                                Content="{DynamicResource RollbackSelectedButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding HasRollbackFolderGroups, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       Text="{DynamicResource UndoByFolderLabel}" />
                            <ItemsControl ItemsSource="{Binding RollbackFolderGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,4,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.RollbackFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding FolderName}"
                                                Content="{Binding Label}"
                                                IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource InverseBooleanConverter}}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PlanSummary}" />
                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryAnalyzedItemsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding TotalItems}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryMoveOperationsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding MoveCount}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryRenameOperationsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding RenameCount}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryItemsNeedingReviewLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding NeedsReviewCount}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryGeminiItemsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding GeminiAssistedCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <TabControl Grid.Column="2" Background="Transparent" BorderThickness="0">
            <TabItem Header="{DynamicResource ActivityTitle}">
                <Border Margin="8" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource SelectedOperationTitle}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource CurrentPathLabel}" />
                        <TextBlock Text="{Binding SelectedOperation.CurrentRelativePath}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ProposedPathLabel}" />
                        <TextBlock Text="{Binding SelectedOperation.ProposedRelativePath}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ReasonLabel}" />
                        <TextBlock Text="{Binding SelectedOperation.Reason}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="{DynamicResource RollbackPreviewTitle}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="{DynamicResource RollbackPreviewHint}" />

                    <StackPanel Grid.Row="1"
                                Margin="0,12,0,0"
                                Visibility="{Binding HasRollbackPreviewEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{DynamicResource RollbackPreviewSummaryTitle}" />
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryReadyLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewReadyCount}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryMissingLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewMissingDestinationCount}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource RollbackPreviewSummaryBlockedLabel}" />
                                    <TextBlock Margin="4,0,0,0" Text="{Binding RollbackPreviewOriginalPathOccupiedCount}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RollbackPreviewEntries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding ExecutedAtLocal, StringFormat={}{0:g}}"
                                                    Header="{DynamicResource RollbackPreviewWhenColumn}" />
                                <DataGridTextColumn Binding="{Binding DestinationRelativePath}"
                                                    Header="{DynamicResource RollbackPreviewCurrentColumn}"
                                                    Width="2*" />
                                <DataGridTextColumn Binding="{Binding SourceRelativePath}"
                                                    Header="{DynamicResource RollbackPreviewRestoreToColumn}"
                                                    Width="2*" />
                                <DataGridTextColumn Binding="{Binding PreviewStatus}"
                                                    Header="{DynamicResource RollbackPreviewStatusColumn}" />
                                <DataGridTextColumn Binding="{Binding Outcome}"
                                                    Header="{DynamicResource RollbackPreviewOutcomeColumn}" />
                                <DataGridTextColumn Binding="{Binding PreviewMessage}"
                                                    Header="{DynamicResource RollbackPreviewExpectedColumn}"
                                                    Width="2*" />
                                <DataGridTextColumn Binding="{Binding Notes}"
                                                    Header="{DynamicResource RollbackPreviewReasonColumn}"
                                                    Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="{Binding HasRollbackPreviewEntries, Converter={StaticResource InverseBooleanConverter}}">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource RollbackPreviewEmpty}" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource LogsTitle}">
                <ListBox Margin="8"
                         BorderThickness="0"
                         ItemsSource="{Binding LogEntries}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Level}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding Category}" />
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding Message}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
