<UserControl x:Class="FileTransformer.App.Views.WizardDedupScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                           Text="{DynamicResource DedupScanTitle}" />
                <TextBlock Margin="0,8,0,16"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource DedupScanHint}" />

                <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                           Text="{DynamicResource RootFolder}" />
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox MinHeight="48"
                             VerticalContentAlignment="Center"
                             Text="{Binding DedupRootFolder, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Style="{StaticResource HeroActionButtonStyle}"
                            Command="{Binding BrowseDedupRootCommand}"
                            Content="{DynamicResource Browse}" />
                </Grid>

                <WrapPanel Margin="0,10,0,0">
                    <Button Style="{StaticResource HeroActionButtonStyle}"
                            Command="{Binding DedupScanCommand}"
                            Content="{DynamicResource DedupScanButton}" />
                    <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                            Command="{Binding CancelCurrentWorkCommand}"
                            Content="{DynamicResource CancelButton}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Style="{StaticResource CompactCardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                           Text="{DynamicResource DedupScanResultsTitle}" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource DedupScanResultsHint}" />
                <TextBlock Margin="0,14,0,0"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="{Binding DedupGroups.Count}" />
                <TextBlock Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource DedupScanGroupsLabel}" />
                <TextBlock Margin="0,14,0,0"
                           Text="{DynamicResource DedupScanEmpty}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDedupGroups}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ItemsControl Margin="0,12,0,0"
                              ItemsSource="{Binding DedupGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Style="{StaticResource SoftPanelBorderStyle}">
                                <TextBlock Text="{Binding DisplayLabel}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
