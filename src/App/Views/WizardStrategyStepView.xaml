<UserControl x:Class="FileTransformer.App.Views.WizardStrategyStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:domain="clr-namespace:FileTransformer.Domain.Enums;assembly=FileTransformer.Domain">
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource StrategySelectionTitle}" />
                <TextBlock Margin="0,8,0,12"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="{DynamicResource StrategySelectionBody}" />
                <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource StrategyPresetLabel}" />
                <ComboBox ItemsSource="{Binding StrategyPresets}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedStrategyPreset}" />

                <Border Margin="0,8,0,0"
                        Padding="12"
                        Background="{StaticResource SurfaceAltBrush}"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{DynamicResource StrategyRecommendationTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{DynamicResource StrategyRecommendationHint}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource CurrentStrategyTitle}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="{Binding StrategyDisplayName}" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="{DynamicResource CurrentStrategyBody}" />

                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding StrategyRecommendations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="12"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="12">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.ApplyStrategyRecommendationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Preset}"
                                                Content="{DynamicResource StrategyRecommendationUseButton}" />
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding Confidence, StringFormat={}{0:P0}}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding Reason}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,10,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="{DynamicResource StrategyRecommendationEmpty}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStrategyRecommendations}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
