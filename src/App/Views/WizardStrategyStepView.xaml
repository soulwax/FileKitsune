<UserControl x:Class="FileTransformer.App.Views.WizardStrategyStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:domain="clr-namespace:FileTransformer.Domain.Enums;assembly=FileTransformer.Domain">
    <Grid Margin="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1.45*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource StrategySelectionTitle}" />
                <TextBlock Margin="0,8,0,12"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource StrategySelectionBody}" />
                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{DynamicResource StrategyPresetLabel}" />
                <ComboBox ItemsSource="{Binding StrategyPresets}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedStrategyPreset}" />

                <Border Margin="0,8,0,0" Style="{StaticResource SoftPanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource CurrentStrategyTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="{Binding StrategyDisplayName}" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{DynamicResource CurrentStrategyBody}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource StrategyRecommendationTitle}" />
                <TextBlock Margin="0,8,0,12"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource StrategyRecommendationHint}" />

                <Border Margin="0,14,0,0"
                        Style="{StaticResource SoftPanelBorderStyle}"
                        Visibility="{Binding HasGeminiOrganizationGuidance, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding GeminiOrganizationGuidanceTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{Binding GeminiOrganizationGuidanceBody}" />
                        <Button Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ApplyGeminiGuidanceCommand}"
                                Content="{DynamicResource GeminiGuidanceApplyButton}" />
                    </StackPanel>
                </Border>

                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding StrategyRecommendations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Style="{StaticResource SoftPanelBorderStyle}">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.ApplyStrategyRecommendationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Preset}"
                                                Content="{DynamicResource StrategyRecommendationUseButton}" />
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding Confidence, StringFormat={}{0:P0}}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource HintTextStyle}"
                                               Text="{Binding Reason}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,10,0,0"
                           Text="{DynamicResource StrategyRecommendationEmpty}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasStrategyRecommendations}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
