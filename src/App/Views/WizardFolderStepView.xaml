<UserControl x:Class="FileTransformer.App.Views.WizardFolderStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource RootFolder}" />
                <TextBlock Margin="0,8,0,16"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource RootFolderStepHint}" />

                <TextBlock Style="{StaticResource FieldLabelTextStyle}" Text="{DynamicResource RootFolder}" />
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Margin="0"
                             MinHeight="42"
                             VerticalContentAlignment="Center"
                             Text="{Binding RootDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Margin="0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding BrowseRootCommand}"
                            Content="{DynamicResource Browse}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CompactCardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{DynamicResource UiLanguageLabel}" />
                <TextBlock Margin="0,8,0,12"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource WizardStepFolderBody}" />
                <ComboBox ItemsSource="{Binding AppLanguages}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedAppLanguage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Style="{StaticResource CompactCardBorderStyle}"
                Visibility="{Binding HasEnvironmentSanityItems, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Margin="0,0,12,0">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="{DynamicResource EnvironmentSanityTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{DynamicResource EnvironmentSanityHint}" />
                        <TextBlock Margin="0,8,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding EnvironmentSanitySummary}" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding PingGeminiEnvironmentCommand}"
                            Content="{DynamicResource EnvironmentSanityPingButton}"
                            IsEnabled="{Binding IsGeminiEnvironmentPingAllowed}" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshEnvironmentSanityCommand}"
                            Content="{DynamicResource EnvironmentSanityRefreshButton}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                </DockPanel>

                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource HintTextStyle}"
                           Text="{Binding GeminiEnvironmentPingAvailabilityMessage}" />

                <Border Margin="0,12,0,0"
                        Style="{StaticResource SoftPanelBorderStyle}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{DynamicResource EnvironmentSanityPingTitle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding GeminiEnvironmentPingStatus}" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{Binding GeminiEnvironmentPingMessage}" />
                    </StackPanel>
                </Border>

                <ItemsControl Margin="0,12,0,0"
                              ItemsSource="{Binding EnvironmentSanityItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="12"
                                    Background="#12FFFFFF"
                                    BorderBrush="#1EFFFFFF"
                                    BorderThickness="1">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StatusLabel}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding DisplayName}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource HintTextStyle}"
                                               Text="{Binding Key}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding ValuePreview}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource HintTextStyle}"
                                               Text="{Binding SourceLabel, StringFormat={}{0}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource HintTextStyle}"
                                               Text="{Binding Message}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
