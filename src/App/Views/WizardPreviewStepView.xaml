<UserControl x:Class="FileTransformer.App.Views.WizardPreviewStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="{DynamicResource PlanPreview}" />
            <TextBlock Margin="0,6,0,16"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="{DynamicResource PreviewIntroText}" />

            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource SummaryItemsAnalyzed}" />
                            <TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding TotalItems}" />
                        </StackPanel>
                        <iconPacks:PackIconMaterial Grid.Column="1"
                                                    Width="26"
                                                    Height="26"
                                                    Foreground="{StaticResource AccentStrongBrush}"
                                                    Kind="FileDocumentOutline" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource SummaryMoves}" />
                            <TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding MoveCount}" />
                        </StackPanel>
                        <iconPacks:PackIconMaterial Grid.Column="1"
                                                    Width="26"
                                                    Height="26"
                                                    Foreground="#31809B"
                                                    Kind="FileMoveOutline" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource SummaryRenames}" />
                            <TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding RenameCount}" />
                        </StackPanel>
                        <iconPacks:PackIconMaterial Grid.Column="1"
                                                    Width="26"
                                                    Height="26"
                                                    Foreground="#8056D6"
                                                    Kind="FileEditOutline" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource SummaryNeedsReview}" />
                            <TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding NeedsReviewCount}" />
                        </StackPanel>
                        <iconPacks:PackIconMaterial Grid.Column="1"
                                                    Width="26"
                                                    Height="26"
                                                    Foreground="#DD6B20"
                                                    Kind="AlertCircleOutline" />
                    </Grid>
                </Border>
            </UniformGrid>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Style="{StaticResource ActionCardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="{DynamicResource PreviewActionTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource HintTextStyle}"
                               Text="{DynamicResource PreviewActionHint}" />
                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Text="{DynamicResource PreviewActionStatusLabel}" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding StatusMessage}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Button Style="{StaticResource HeroActionButtonStyle}"
                            Command="{Binding ScanCommand}"
                            Content="{DynamicResource ScanButton}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                    <WrapPanel Margin="0,10,0,0">
                        <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                                Command="{Binding SaveSettingsCommand}"
                                Content="{DynamicResource SaveButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                        <Button Margin="0,0,0,8"
                                Style="{StaticResource ProminentSecondaryButtonStyle}"
                                Command="{Binding CancelCurrentWorkCommand}"
                                Content="{DynamicResource CancelButton}"
                                IsEnabled="{Binding IsBusy}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Border Padding="10,6"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource SummaryGeminiItemsLabel}" />
                            <TextBlock Margin="4,0,0,0" Text="{Binding GeminiAssistedCount}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource PreviewFilterLabel}" />
                    <ComboBox Width="180"
                              Margin="10,0,0,0"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding PlanFilters}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedPlanFilter}" />
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource ProminentSecondaryButtonStyle}"
                            Command="{Binding SelectExecutableCommand}"
                            Content="{DynamicResource SelectExecutableButton}" />
                    <Button Margin="8,0,0,0"
                            Style="{StaticResource ProminentSecondaryButtonStyle}"
                            Command="{Binding ClearSelectionCommand}"
                            Content="{DynamicResource ClearSelectionButton}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding PlanView}"
                      SelectedItem="{Binding SelectedOperation}"
                      AlternationCount="2"
                      RowHeight="34"
                      ColumnHeaderHeight="36">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Operation.RequiresReview}" Value="True">
                                <Setter Property="Background" Value="#FFFFF3E4" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDuplicateGroupSelected}" Value="True">
                                <Setter Property="Background" Value="#FFE8F4FF" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CanSelect}" Value="False">
                                <Setter Property="Opacity" Value="0.75" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{DynamicResource GridRun}" Width="52">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          IsEnabled="{Binding CanSelect}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource GridAction}" Binding="{Binding OperationType}" Width="105" />
                    <DataGridTemplateColumn Header="" Width="42">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <iconPacks:PackIconFileIcons Width="22"
                                                             Height="22"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding FileTypeIconBrush}"
                                                             Kind="{Binding FileTypeIconKind}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource GridCurrentPath}" Binding="{Binding CurrentRelativePath}" Width="210" />
                    <DataGridTextColumn Header="{DynamicResource GridProposedPath}" Binding="{Binding ProposedRelativePath}" Width="250" />
                    <DataGridTextColumn Header="{DynamicResource GridCategory}" Binding="{Binding Category}" Width="135" />
                    <DataGridTextColumn Header="{DynamicResource GridConfidence}" Binding="{Binding Confidence}" Width="90" />
                    <DataGridTextColumn Header="{DynamicResource GridRisk}" Binding="{Binding Risk}" Width="80" />
                    <DataGridTextColumn Header="{DynamicResource GridLanguage}" Binding="{Binding Language}" Width="95" />
                    <DataGridTextColumn Header="{DynamicResource GridGemini}" Binding="{Binding Gemini}" Width="130" />
                    <DataGridTemplateColumn Header="{DynamicResource GridDuplicate}" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource DuplicateNone}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DuplicateDetected}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DuplicateDetected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{DynamicResource DuplicateOfPrefix}" />
                                        <Run Text="{Binding DuplicateOfRelativePath}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource GridWarnings}" Binding="{Binding Warnings}" Width="180" />
                    <DataGridTextColumn Header="{DynamicResource GridReason}" Binding="{Binding Reason}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconFileIcons Width="28"
                                                     Height="28"
                                                     Margin="0,0,10,0"
                                                     VerticalAlignment="Center"
                                                     Foreground="{Binding SelectedOperation.FileTypeIconBrush}"
                                                     Kind="{Binding SelectedOperation.FileTypeIconKind}" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource SelectedOperationTitle}" />
                    </StackPanel>
                    <TextBlock Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource CurrentPathLabel}" />
                    <TextBlock Text="{Binding SelectedOperation.CurrentRelativePath}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ProposedPathLabel}" />
                    <TextBlock Text="{Binding SelectedOperation.ProposedRelativePath}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource ReasonLabel}" />
                    <TextBlock Text="{Binding SelectedOperation.Reason}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{DynamicResource DuplicateLabel}" />
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DuplicateNone}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedOperation.DuplicateDetected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedOperation.DuplicateDetected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{DynamicResource DuplicateOfPrefix}" />
                            <Run Text="{Binding SelectedOperation.DuplicateOfRelativePath}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="16">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PreviewSelectionTitle}" />
                    <TextBlock Margin="0,6,0,10"
                               Style="{StaticResource HintTextStyle}"
                               Text="{DynamicResource PlanSummary}" />
                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SummaryAnalyzedItemsLabel}" />
                        <TextBlock Margin="4,0,0,0" Text="{Binding TotalItems}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SummaryMoveOperationsLabel}" />
                        <TextBlock Margin="4,0,0,0" Text="{Binding MoveCount}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SummaryRenameOperationsLabel}" />
                        <TextBlock Margin="4,0,0,0" Text="{Binding RenameCount}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SummaryItemsNeedingReviewLabel}" />
                        <TextBlock Margin="4,0,0,0" Text="{Binding NeedsReviewCount}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SummaryDuplicatesLabel}" />
                        <TextBlock Margin="4,0,0,0" Text="{Binding DuplicateCount}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SummaryGeminiItemsLabel}" />
                        <TextBlock Margin="4,0,0,0" Text="{Binding GeminiAssistedCount}" />
                    </StackPanel>
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="{DynamicResource PreviewCoverageTitle}" />
                    <TextBlock Text="{Binding CoverageSummaryText}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,8,0,0"
                            Padding="10"
                            Background="#FFFFF3E4"
                            BorderBrush="#FFDD6B20"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding HasCoverageWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding CoverageWarningText}"
                                   TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="{DynamicResource DuplicateGroupsLabel}" />
                    <TextBlock Text="{DynamicResource DuplicateGroupsEmpty}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDuplicateGroups}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDuplicateGroups}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding DisplayLabel}" />
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding DuplicateList}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,12,0,4"
                               FontWeight="SemiBold"
                               Text="{DynamicResource DuplicateReviewLabel}" />
                    <TextBlock Text="{DynamicResource DuplicateReviewHint}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDuplicateGroups}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDuplicateGroups}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ComboBox ItemsSource="{Binding DuplicateGroups}"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectedItem="{Binding SelectedDuplicateGroup}" />
                        <Button Margin="0,8,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SelectDuplicateGroupOperationsCommand}"
                                Content="{DynamicResource DuplicateReviewSelectButton}" />
                        <TextBlock Margin="0,10,0,4"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="{DynamicResource DuplicateGroupDetailsLabel}" />
                        <TextBlock Text="{DynamicResource DuplicateGroupDetailsEmpty}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedDuplicateGroup}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding DuplicateGroupOperations}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedDuplicateGroup}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <CheckBox DockPanel.Dock="Left"
                                                  VerticalAlignment="Center"
                                                  IsEnabled="{Binding CanSelect}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="{Binding CurrentRelativePath}" TextWrapping="Wrap" />
                                            <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                       Text="{Binding OperationType}" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
