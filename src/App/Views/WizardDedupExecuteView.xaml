<UserControl x:Class="FileTransformer.App.Views.WizardDedupExecuteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="2">
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                           Text="{DynamicResource DedupExecuteTitle}" />
                <TextBlock Margin="0,8,0,14"
                           Style="{StaticResource HintTextStyle}"
                           Text="{DynamicResource DedupExecuteHint}" />

                <WrapPanel>
                    <Button Style="{StaticResource HeroActionButtonStyle}"
                            Command="{Binding DedupExecuteCommand}"
                            Content="{DynamicResource DedupExecuteButton}" />
                    <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                            Command="{Binding ScanAnotherFolderCommand}"
                            Content="{DynamicResource DedupExecuteScanAnotherButton}" />
                    <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                            Command="{Binding OpenDedupQuarantineFolderCommand}"
                            Content="{DynamicResource DedupExecuteOpenQuarantineButton}" />
                    <Button Style="{StaticResource ProminentSecondaryButtonStyle}"
                            Command="{Binding RestoreDedupQuarantineCommand}"
                            Content="{DynamicResource DedupExecuteRestoreQuarantineButton}"
                            IsEnabled="{Binding HasDedupQuarantineRecords}" />
                </WrapPanel>

                <Border Margin="0,18,0,0"
                        Style="{StaticResource SoftPanelBorderStyle}"
                        Visibility="{Binding HasDedupExecutionResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="{Binding DedupExecutionSummary}" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{DynamicResource DedupExecuteResultsHint}" />
                        <StackPanel Margin="0,10,0,0"
                                    Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{DynamicResource DedupExecuteAuditLabel}" />
                            <TextBlock Margin="6,0,0,0"
                                       Text=":" />
                            <TextBlock Margin="6,0,0,0"
                                       Style="{StaticResource HintTextStyle}"
                                       Text="{Binding DedupLastAuditPath}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0"
                                    Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{DynamicResource DedupExecuteQuarantineLabel}" />
                            <TextBlock Margin="6,0,0,0"
                                       Text=":" />
                            <TextBlock Margin="6,0,0,0"
                                       Style="{StaticResource HintTextStyle}"
                                       Text="{Binding DedupLastQuarantinePath}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ItemsControl Margin="0,12,0,0"
                                      ItemsSource="{Binding DedupExecutionErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,6"
                                               Style="{StaticResource HintTextStyle}"
                                               Text="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
