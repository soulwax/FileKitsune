<UserControl x:Class="FileTransformer.App.Views.WizardLegalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="4">
        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Text="{DynamicResource LegalTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource HintTextStyle}"
                               Text="{DynamicResource LegalIntro}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,16,0,16"
                        Style="{StaticResource SoftPanelBorderStyle}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{DynamicResource LegalWarrantyTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{DynamicResource LegalWarrantyBody}" />
                        <TextBlock Margin="0,12,0,0"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource LegalLicenseTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource HintTextStyle}"
                                   Text="{DynamicResource LegalLicenseBody}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Background="{StaticResource SurfaceTintBrush}">
                    <TextBox Padding="14"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             Height="360"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Text="{Binding LegalLicenseText}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" />
                </Border>

                <StackPanel Grid.Row="3"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding CloseLegalCommand}"
                            Content="{DynamicResource LegalBackButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
