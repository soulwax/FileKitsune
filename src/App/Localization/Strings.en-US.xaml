<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <sys:String x:Key="AppTitle">FileTransformer</sys:String>
    <sys:String x:Key="AppSubtitle">Semantic preview-first organization for multilingual Windows folders</sys:String>
    <sys:String x:Key="RootFolder">Root folder</sys:String>
    <sys:String x:Key="Browse">Browse</sys:String>
    <sys:String x:Key="GeneralSettings">General settings</sys:String>
    <sys:String x:Key="NamingRules">Naming rules</sys:String>
    <sys:String x:Key="GeminiSettings">Gemini settings</sys:String>
    <sys:String x:Key="PlannerDimensions">Planner dimensions</sys:String>
    <sys:String x:Key="PreviewActions">Preview actions</sys:String>
    <sys:String x:Key="ScanButton">Scan and preview</sys:String>
    <sys:String x:Key="SaveButton">Save settings</sys:String>
    <sys:String x:Key="ExecuteButton">Execute selected</sys:String>
    <sys:String x:Key="CancelButton">Cancel</sys:String>
    <sys:String x:Key="RollbackButton">Rollback latest</sys:String>
    <sys:String x:Key="UndoByFolderLabel">Undo by folder:</sys:String>
    <sys:String x:Key="SelectExecutableButton">Select executable</sys:String>
    <sys:String x:Key="ClearSelectionButton">Clear selection</sys:String>
    <sys:String x:Key="PlanPreview">Plan preview</sys:String>
    <sys:String x:Key="PlanSummary">Plan summary</sys:String>
    <sys:String x:Key="LogsTitle">Logs</sys:String>
    <sys:String x:Key="ActivityTitle">What this plan does</sys:String>
    <sys:String x:Key="GridRun">Run</sys:String>
    <sys:String x:Key="GridAction">Action</sys:String>
    <sys:String x:Key="GridCurrentPath">Current path</sys:String>
    <sys:String x:Key="GridProposedPath">Proposed path</sys:String>
    <sys:String x:Key="GridCategory">Category</sys:String>
    <sys:String x:Key="GridConfidence">Confidence</sys:String>
    <sys:String x:Key="GridRisk">Risk</sys:String>
    <sys:String x:Key="GridReason">Reason</sys:String>
    <sys:String x:Key="GridWarnings">Warnings</sys:String>
    <sys:String x:Key="GridLanguage">Language</sys:String>
    <sys:String x:Key="GridGemini">Classifier</sys:String>
    <sys:String x:Key="WizardLabel">Wizard</sys:String>
    <sys:String x:Key="WizardBackButton">Back</sys:String>
    <sys:String x:Key="WizardNextButton">Next</sys:String>
    <sys:String x:Key="SafetyGuardrailsTitle">Safety guardrails</sys:String>
    <sys:String x:Key="SafetyGuardrailsBody">Preview-first, in-root moves only, no deletions, no silent overwrites.</sys:String>
    <sys:String x:Key="RootFolderStepHint">Choose the folder you want to analyze and reorganize. The wizard keeps all later actions scoped to this root.</sys:String>
    <sys:String x:Key="WizardStepFolderTitle">Step 1: Folder selection</sys:String>
    <sys:String x:Key="WizardStepFolderBody">Pick the root folder for analysis. Nothing is executed here; this step only defines the safe workspace.</sys:String>
    <sys:String x:Key="WizardStepStrategyTitle">Step 2: Strategy selection</sys:String>
    <sys:String x:Key="WizardStepStrategyBody">Choose the primary organization approach before tuning low-level rules.</sys:String>
    <sys:String x:Key="WizardStepRulesTitle">Step 3: Rule configuration</sys:String>
    <sys:String x:Key="WizardStepRulesBody">Review scan limits, naming rules, dimensions, and Gemini settings before building a preview.</sys:String>
    <sys:String x:Key="WizardStepPreviewTitle">Step 4: Preview</sys:String>
    <sys:String x:Key="WizardStepPreviewBody">Build and inspect the plan, warnings, and selectable operations before any execution is allowed.</sys:String>
    <sys:String x:Key="WizardStepExecuteTitle">Step 5: Execute and rollback</sys:String>
    <sys:String x:Key="WizardStepExecuteBody">Run selected operations and review rollback and activity information in one place.</sys:String>
</ResourceDictionary>
