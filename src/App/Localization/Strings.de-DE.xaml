    <sys:String x:Key="SafetyGuardrailsTitle">Sicherheitsregeln</sys:String>
    <sys:String x:Key="SafetyGuardrailsBody">Vorschau zuerst, nur Verschiebungen im Stammordner, keine Löschungen, kein stilles Überschreiben.</sys:String>
    <sys:String x:Key="RootFolderStepHint">Wählen Sie den Ordner, der analysiert und organisiert werden soll. Alle späteren Aktionen bleiben auf diesen Stammordner begrenzt.</sys:String>
    <sys:String x:Key="WizardStepModeSelectorTitle">Arbeitsmodus wählen</sys:String>
    <sys:String x:Key="WizardStepModeSelectorBody">Wählen Sie zuerst, ob FileKitsune Ordner organisieren oder exakte Duplikate finden soll.</sys:String>
    <sys:String x:Key="WizardStepFolderTitle">Schritt 1: Ordnerauswahl</sys:String>
    <sys:String x:Key="WizardStepFolderBody">Wählen Sie den Stammordner für die Analyse. In diesem Schritt wird noch nichts ausgeführt; er definiert nur den sicheren Arbeitsbereich.</sys:String>
    <sys:String x:Key="WizardStepStrategyTitle">Schritt 2: Strategieauswahl</sys:String>
    <sys:String x:Key="WizardStepStrategyBody">Wählen Sie zuerst den grundlegenden Organisationsansatz und passen Sie danach die Detailregeln an.</sys:String>
    <sys:String x:Key="WizardStepRulesTitle">Schritt 3: Regelkonfiguration</sys:String>
    <sys:String x:Key="WizardStepRulesBody">Prüfen Sie Scan-Grenzen, Benennungsregeln, Dimensionen und Gemini-Einstellungen, bevor eine Vorschau erstellt wird.</sys:String>
    <sys:String x:Key="WizardStepPreviewTitle">Schritt 4: Vorschau</sys:String>
    <sys:String x:Key="WizardStepPreviewBody">Erstellen und prüfen Sie den Plan, Hinweise und auswählbare Operationen, bevor etwas ausgeführt werden darf.</sys:String>
    <sys:String x:Key="WizardStepExecuteTitle">Schritt 5: Ausführen und Rückgängig machen</sys:String>
    <sys:String x:Key="WizardStepExecuteBody">Führen Sie ausgewählte Operationen aus und behalten Sie Rollback- und Aktivitätsinformationen an einem Ort im Blick.</sys:String>
    <sys:String x:Key="WizardStepDedupScanTitle">Duplikate: Scan</sys:String>
    <sys:String x:Key="WizardStepDedupScanBody">Wählen Sie einen Ordner und erkennen Sie exakte Duplikate per Dateigröße und SHA-256-Hash.</sys:String>
    <sys:String x:Key="WizardStepDedupReviewTitle">Duplikate: Prüfen</sys:String>
    <sys:String x:Key="WizardStepDedupReviewBody">Legen Sie pro Gruppe fest, welche Datei behalten wird. Noch wird nichts gelöscht.</sys:String>
    <sys:String x:Key="WizardStepDedupExecuteTitle">Duplikate: Ausführen</sys:String>
    <sys:String x:Key="WizardStepDedupExecuteBody">Bestätigte Kopien werden in die FileKitsune-Quarantäne verschoben und können explizit wiederhergestellt werden.</sys:String>
    <sys:String x:Key="WizardStepLegalTitle">Rechtliches</sys:String>
    <sys:String x:Key="WizardStepLegalBody">Lizenz- und Gewährleistungsinformationen zu FileKitsune.</sys:String>
    <sys:String x:Key="ModeOrganizeTitle">Dateien organisieren</sys:String>
    <sys:String x:Key="ModeOrganizeBody">Den bekannten 5-Schritt-Assistenten nutzen: Ordner wählen, Strategie und Regeln setzen, Vorschau prüfen, dann gezielt ausführen.</sys:String>
    <sys:String x:Key="ModeOrganizeAction">Organisationsmodus öffnen</sys:String>
    <sys:String x:Key="ModeDedupTitle">Duplikate finden</sys:String>
    <sys:String x:Key="ModeDedupBody">Einen Ordner nach exakten Kopien durchsuchen, Keeper pro Gruppe auswählen und bestätigte Kopien in die FileKitsune-Quarantäne verschieben.</sys:String>
    <sys:String x:Key="ModeDedupAction">Duplikatmodus öffnen</sys:String>
    <sys:String x:Key="DedupScanTitle">Ordner nach exakten Duplikaten scannen</sys:String>
    <sys:String x:Key="DedupScanHint">FileKitsune hasht nur Größenkandidaten und trifft keine Entfernungsentscheidung ohne Ihre Prüfung.</sys:String>
    <sys:String x:Key="DedupScanButton">Duplikate scannen</sys:String>
    <sys:String x:Key="DedupScanResultsTitle">Scan-Ergebnis</sys:String>
    <sys:String x:Key="DedupScanResultsHint">Nach dem Scan können Sie gefundene Gruppen im nächsten Schritt prüfen.</sys:String>
    <sys:String x:Key="DedupScanGroupsLabel">Duplikatgruppen</sys:String>
    <sys:String x:Key="DedupScanEmpty">Noch keine Duplikatgruppen gefunden.</sys:String>
    <sys:String x:Key="DedupReviewGroupsTitle">Gruppen</sys:String>
    <sys:String x:Key="DedupReviewTally">{0} Gruppen · {1} bestätigt · {2} übersprungen</sys:String>
    <sys:String x:Key="DedupReviewResolveAllButton">Alle automatisch bestätigen</sys:String>
    <sys:String x:Key="DedupReviewFilesTitle">Dateien in der Gruppe</sys:String>
    <sys:String x:Key="DedupReviewFilesHint">Der Keeper bleibt erhalten. Alle anderen Dateien dieser bestätigten Gruppe werden später in die FileKitsune-Quarantäne verschoben.</sys:String>
    <sys:String x:Key="DedupReviewKeepBadge">Behalten</sys:String>
    <sys:String x:Key="DedupReviewRemoveBadge">Entfernen</sys:String>
    <sys:String x:Key="DedupReviewSetKeeperButton">Als Keeper</sys:String>
