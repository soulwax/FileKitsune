    <sys:String x:Key="RollbackTitle">Rückgängig machen</sys:String>
    <sys:String x:Key="RollbackBody">Das Rückgängigmachen unterstützt in diesem Schritt weiterhin nur den letzten Lauf. Historische Rücknahmen folgen im dedizierten Rollback-Ausbau.</sys:String>
